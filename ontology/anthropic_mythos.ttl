        "A reusable conceptual node for abstractions, mechanisms, or analytical ideas."@en .

:FlowStep a owl:Class ;
    rdfs:label "Flow step"@en ;
    rdfs:comment "An ordered step in a logic flow."@en,
        "An ordered step inside a causal or logic flow."@en .

:QuotedPassage a owl:Class ;
    rdfs:label "Quoted passage"@en ;
    rdfs:comment "An exact passage extracted from a source page for citation."@en .

:DocumentSection a owl:Class ;
    rdfs:label "Document section"@en ;
    rdfs:comment "A section or subsection derived from the PDF outline."@en .

:SourcePage a owl:Class ;
