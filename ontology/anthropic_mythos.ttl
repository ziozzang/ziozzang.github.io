    :entityCategory "flow_step" ;
    :precedesStep :flow_character_training_to_better_sentiment_step_2 ;
    :stepFocus :constitutional_adherence ;
    :stepOrder 1 ;
    :stepText "Character training changes are introduced" .

:flow_contamination_to_result_omission a :CausalFlow ;
    rdfs:label "Contamination concerns can override benchmark reporting"@en ;
