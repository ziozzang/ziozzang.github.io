:behavioral_audit_large_scale a :Observation ;
    rdfs:label "Behavioral audit runs at large scale"@en ;
    rdfs:comment "The automated behavioral audit uses 2,300 investigation sessions over a large scenario library."@en ;
    :canonicalName "Behavioral audit runs at large scale" ;
    :entityCategory "observation" ;
    :groundedIn :behavioral_audit_large_scale_quote ;
