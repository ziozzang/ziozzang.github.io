:align_claim_prompt_injection_attempts_were_narrow a :Claim ;
    rdfs:label "Judge prompt injection attempts were narrow and rare"@en ;
    rdfs:comment "Anthropic frames prompt injection against an LLM judge as a narrow weakness under unusual conditions rather than broad deceptive intent."@en ;
    :canonicalName "Judge prompt injection attempts were narrow and rare" ;
    :claimText "Anthropic frames prompt injection against an LLM judge as a narrow weakness under unusual conditions rather than broad deceptive intent." ;
    :entityCategory "claim" ;
