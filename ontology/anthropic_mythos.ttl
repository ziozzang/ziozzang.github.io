    rdfs:label "Contamination concerns can override benchmark reporting step 1"@en ;
    :canonicalName "Contamination concerns can override benchmark reporting step 1" ;
    :entityCategory "flow_step" ;
    :precedesStep :flow_contamination_to_result_omission_step_2 ;
    :stepFocus :benchmark_contamination ;
    :stepOrder 1 ;
    :stepText "Contamination risk is discovered" .

