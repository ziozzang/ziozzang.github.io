    :canonicalName "Autonomous engineering capability changes the human workflow step 1" ;
    :entityCategory "flow_step" ;
    :precedesStep :flow_agentic_engineering_to_set_and_forget_step_2 ;
    :stepFocus :autonomous_engineering_cycle ;
    :stepOrder 1 ;
    :stepText "The model can run the whole engineering cycle" .

:flow_benchmark_saturation_to_real_world_cyber_evals a :CausalFlow ;
    rdfs:label "Cyber benchmark saturation pushes evaluation toward real-world tasks"@en ;
    dcterms:isPartOf :section_3_1_introduction ;
    rdfs:comment "Because existing cyber benchmarks saturate, Anthropic shifts evaluation philosophy toward real-world vulnerability discovery and exploit development tasks."@en ;
    :canonicalName "Cyber benchmark saturation pushes evaluation toward real-world tasks" ;
    :entityCategory "logic_flow" ;
    :flowFrom :benchmark_saturation ;
    :flowSummary "Because existing cyber benchmarks saturate, Anthropic shifts evaluation philosophy toward real-world vulnerability discovery and exploit development tasks." ;
    :flowTo :exploit_development ;
    :flowVia :real_world_task_focus,
        :zero_day_discovery ;
    :groundedIn :flow_benchmark_saturation_to_real_world_cyber_evals_quote ;
    :hasFlowStep :flow_benchmark_saturation_to_real_world_cyber_evals_step_1,
        :flow_benchmark_saturation_to_real_world_cyber_evals_step_2,
        :flow_benchmark_saturation_to_real_world_cyber_evals_step_3,
        :flow_benchmark_saturation_to_real_world_cyber_evals_step_4 .

:flow_benchmark_saturation_to_real_world_cyber_evals_quote a :QuotedPassage ;
    rdfs:label "Quoted support for Cyber benchmark saturation pushes evaluation toward real-world tasks"@en ;
    :canonicalName "Quoted support for Cyber benchmark saturation pushes evaluation toward real-world tasks" ;
    :entityCategory "quote" ;
    :quoteText """Claude Mythos Preview is the most cyber-capable model we have released, surpassing all
previous models across our internal evaluation suite and saturating nearly all of our
existing internal and known external capability evaluations. As model capabilities have
improved, we have re-oriented our evaluation philosophy to focus on performance on
meaningful, real-world cybersecurity tasks over static benchmarks. We have found that
Claude Mythos Preview is a step-change in vulnerability discovery and exploitation: using
an agentic harness with minimal human steering, it is able to autonomously find zero-days
in both open-source and closed-source software tested under authorized disclosure
programs or arrangements, and in many cases, develop the identified vulnerabilities into
working proof-of-concept exploits. We outline the results of our pre-release findings on
real-world tasks in more detail in an accompanying blog post.""" ;
    :quotedFromPage :page_046 ;
    :sourceAnchor "https://www-cdn.anthropic.com/8b8380204f74670be75e81c820ca8dda846ab289.pdf#page=46"^^xsd:anyURI .

:flow_benchmark_saturation_to_real_world_cyber_evals_step_1 a :FlowStep ;
    rdfs:label "Cyber benchmark saturation pushes evaluation toward real-world tasks step 1"@en ;
    :canonicalName "Cyber benchmark saturation pushes evaluation toward real-world tasks step 1" ;
    :entityCategory "flow_step" ;
    :precedesStep :flow_benchmark_saturation_to_real_world_cyber_evals_step_2 ;
    :stepFocus :benchmark_saturation ;
    :stepOrder 1 ;
    :stepText "Existing cyber evaluations saturate" .

:flow_capability_gain_to_low_catastrophic_risk a :CausalFlow ;
    rdfs:label "Capability gains are filtered through mitigation-backed risk judgment"@en ;
    dcterms:isPartOf :section_2_1_3_summary_of_findings_and_conclusions ;
    rdfs:comment "Capability gains do not automatically trigger a catastrophic-risk conclusion; instead, Anthropic treats the conclusion as a mitigation-sensitive judgment call under RSP 3.x."@en ;
    :canonicalName "Capability gains are filtered through mitigation-backed risk judgment" ;
    :entityCategory "logic_flow" ;
    :flowFrom :capability_gain ;
    :flowSummary "Capability gains do not automatically trigger a catastrophic-risk conclusion; instead, Anthropic treats the conclusion as a mitigation-sensitive judgment call under RSP 3.x." ;
    :flowTo :catastrophic_risk_remains_low ;
    :flowVia :benchmark_saturation,
        :classifier_guards,
        :judgment_call ;
    :groundedIn :flow_capability_gain_to_low_catastrophic_risk_quote ;
    :hasFlowStep :flow_capability_gain_to_low_catastrophic_risk_step_1,
        :flow_capability_gain_to_low_catastrophic_risk_step_2,
        :flow_capability_gain_to_low_catastrophic_risk_step_3,
        :flow_capability_gain_to_low_catastrophic_risk_step_4,
        :flow_capability_gain_to_low_catastrophic_risk_step_5 .

:flow_capability_gain_to_low_catastrophic_risk_quote a :QuotedPassage ;
    rdfs:label "Quoted support for Capability gains are filtered through mitigation-backed risk judgment"@en ;
    :canonicalName "Quoted support for Capability gains are filtered through mitigation-backed risk judgment" ;
    :entityCategory "quote" ;
    :quoteText """Claude Mythos Preview is significantly more capable than Claude Opus 4.6, the most
capable model discussed in our most recent Risk Report. Despite these improved
capabilities, our overall conclusion is that catastrophic risks remain low. This determination
involves judgment calls. The model is demonstrating high levels of capability and saturates
many of our most concrete, objectively-scored evaluations, leaving us with approaches that
involve more fundamental uncertainty, such as examining trends in performance for
acceleration (highly noisy and backward-looking) and collecting reports about model
strengths and weaknesses from internal users (inherently subjective, and not necessarily
reliable).""" ;
    :quotedFromPage :page_017 ;
    :sourceAnchor "https://www-cdn.anthropic.com/8b8380204f74670be75e81c820ca8dda846ab289.pdf#page=17"^^xsd:anyURI .

:flow_capability_gain_to_low_catastrophic_risk_step_1 a :FlowStep ;
    rdfs:label "Capability gains are filtered through mitigation-backed risk judgment step 1"@en ;
    :canonicalName "Capability gains are filtered through mitigation-backed risk judgment step 1" ;
    :entityCategory "flow_step" ;
    :precedesStep :flow_capability_gain_to_low_catastrophic_risk_step_2 ;
    :stepFocus :capability_gain ;
    :stepOrder 1 ;
    :stepText "Capability gains outpace prior Claude models" .

