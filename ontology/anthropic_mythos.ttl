:flow_capability_to_alignment_risk_quote a :QuotedPassage ;
    rdfs:label "Quoted support for More capability raises alignment risk through three channels"@en ;
    :canonicalName "Quoted support for More capability raises alignment risk through three channels" ;
    :entityCategory "quote" ;
    :quoteText """Claude Mythos Preview's capabilities on autonomous research and engineering far exceed
that of our prior models. As in the analogy above, this increases the risk that the model
poses in three ways:""" ;
    :quotedFromPage :page_053 ;
    :sourceAnchor "https://www-cdn.anthropic.com/8b8380204f74670be75e81c820ca8dda846ab289.pdf#page=53"^^xsd:anyURI .

