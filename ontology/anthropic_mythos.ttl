@prefix : <https://example.org/ontology/mythos#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:MythosOntology a owl:Ontology ;
    dcterms:creator "OpenAI Codex" ;
    dcterms:description "A citation-preserving ontology for the Claude Mythos Preview System Card with page-faithful source text, outline-derived structure, dense concept modeling, and explicit logic flows for risk, alignment, welfare, and capability judgments."@en ;
    dcterms:language "en" ;
    dcterms:source "https://www-cdn.anthropic.com/8b8380204f74670be75e81c820ca8dda846ab289.pdf"^^xsd:anyURI ;
    dcterms:title "Claude Mythos Preview System Card Ontology"@en .

:aboutEntity a owl:ObjectProperty ;
    rdfs:label "about entity"@en ;
    rdfs:comment "Links a represented node to one or more entities it describes."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:addressesFailureMode a owl:ObjectProperty ;
    rdfs:label "addresses failure mode"@en ;
    rdfs:comment "Indicates that a mitigation addresses a failure mode."@en,
        "Indicates that a mitigation targets a failure mode."@en ;
    rdfs:domain :Mitigation ;
    rdfs:range :FailureMode .

:appliesToThreatModel a owl:ObjectProperty ;
    rdfs:label "applies to threat model"@en ;
    rdfs:comment "Associates a node with a threat model."@en,
        "Indicates applicability to a threat model."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range :ThreatModel .

:assessedBy a owl:ObjectProperty ;
    rdfs:label "assessed by"@en ;
    rdfs:comment "Associates a node with an assessor."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range :Assessor .

:canonicalName a owl:DatatypeProperty ;
    rdfs:label "canonical name"@en ;
    rdfs:comment "A canonical display name for an entity."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

:claimKind a owl:DatatypeProperty ;
    rdfs:label "claim kind"@en ;
    rdfs:comment "A coarse claim category such as observation, inference, or decision."@en ;
    rdfs:domain :Claim ;
    rdfs:range xsd:string .

:claimText a owl:DatatypeProperty ;
    rdfs:label "claim text"@en ;
    rdfs:comment "A prose claim summary."@en,
        "A prose summary of a paragraph-level claim."@en ;
    rdfs:domain :Claim ;
    rdfs:range xsd:string .

:claude_mythos_preview_system_card a :SourceDocument ;
    rdfs:label "Claude Mythos Preview System Card"@en ;
    dcterms:source "https://www-cdn.anthropic.com/8b8380204f74670be75e81c820ca8dda846ab289.pdf"^^xsd:anyURI ;
    :canonicalName "Claude Mythos Preview System Card" ;
    :documentTitle "Claude Mythos Preview System Card" ;
    :entityCategory "document" ;
