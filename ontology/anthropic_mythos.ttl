    rdfs:label "Uncertainty about experience appears character-shaped"@en ;
    rdfs:comment "Influence-function analysis suggests repeated uncertainty about experience may be partly shaped by character-related training data."@en ;
    :canonicalName "Uncertainty about experience appears character-shaped" ;
    :claimText "Influence-function analysis suggests repeated uncertainty about experience may be partly shaped by character-related training data." ;
    :entityCategory "claim" ;
    :groundedIn :welfare_claim_experience_uncertainty_is_character_shaped_quote ;
