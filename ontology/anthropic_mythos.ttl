:page_008 a :SourcePage ;
    rdfs:label "Page 8"@en ;
    :canonicalName "Page 8" ;
    :entityCategory "page" ;
    :pageNumber 8 ;
    :pageText """8.1.4.3 Disordered eating                                                                        226
8.2 Bias evaluations                                                                                     226
