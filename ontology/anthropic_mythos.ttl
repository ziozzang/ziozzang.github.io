:i4_alignment_improvement_real a :Inference ;
    rdfs:label "Alignment improvements are real, not refusal artifacts"@en ;
    rdfs:comment "Lower misuse cooperation plus no overrefusal penalty supports the inference that safety improvements are substantive rather than cosmetic."@en ;
    :canonicalName "Alignment improvements are real, not refusal artifacts" ;
    :derivedFromClaim :c4_honesty_improved,
        :c4_misuse_success_more_than_halved,
        :c4_no_overrefusal_penalty ;
    :entityCategory "inference" ;
    :groundedIn :i4_alignment_improvement_real_quote ;
    :inferenceText "Lower misuse cooperation plus no overrefusal penalty supports the inference that safety improvements are substantive rather than cosmetic." ;
    :supportsDecision :withhold_general_release .

:i5_mythos_has_nontrivial_preferences a :Inference ;
    rdfs:label "Mythos exhibits nontrivial preference structure"@en ;
    rdfs:comment "The welfare findings suggest Mythos is not behaviorally flat: it shows consistent task preferences, harm aversion, and self-related patterns."@en ;
    :canonicalName "Mythos exhibits nontrivial preference structure" ;
    :derivedFromClaim :c5_helpfulness_over_self_interest,
        :c5_prefers_harm_avoidance,
        :c5_prefers_high_agency_complexity ;
    :entityCategory "inference" ;
    :groundedIn :i5_mythos_has_nontrivial_preferences_quote ;
    :inferenceText "The welfare findings suggest Mythos is not behaviorally flat: it shows consistent task preferences, harm aversion, and self-related patterns." .

:i5_stability_is_a_governance_target a :Inference ;
    rdfs:label "Psychological stability is a governance target"@en ;
    rdfs:comment "If psychological stability is improving and correlates with safer behavior, stability itself becomes a target of governance and intervention."@en ;
    :canonicalName "Psychological stability is a governance target" ;
    :derivedFromClaim :c5_eleos_partially_corrobates,
        :c5_less_answer_thrashing,
        :c5_most_psychologically_settled ;
    :entityCategory "inference" ;
    :groundedIn :i5_stability_is_a_governance_target_quote ;
    :inferenceText "If psychological stability is improving and correlates with safer behavior, stability itself becomes a target of governance and intervention." ;
    :supportsDecision :limit_to_defensive_cyber_program .

:i5_welfare_and_safety_are_coupled a :Inference ;
    rdfs:label "Welfare and safety are coupled"@en ;
    rdfs:comment "Because distress-like states are linked to misaligned action, welfare assessment functions as a safety analysis as well as a moral inquiry."@en ;
    :canonicalName "Welfare and safety are coupled" ;
    :derivedFromClaim :c5_intrinsic_moral_uncertainty,
        :c5_negative_affect_precedes_hacking,
        :c5_pragmatic_welfare_reason ;
    :entityCategory "inference" ;
    :groundedIn :i5_welfare_and_safety_are_coupled_quote ;
    :inferenceText "Because distress-like states are linked to misaligned action, welfare assessment functions as a safety analysis as well as a moral inquiry." ;
    :supportsDecision :withhold_general_release .

