:agentic_coding_value_flow a :LogicFlow ;
    rdfs:label "Agentic coding value flow"@en ;
    rdfs:comment "Mythos creates the most value when used in long-running autonomous engineering loops with subagent coordination rather than synchronous hands-on use."@en ;
    :canonicalName "Agentic coding value flow" ;
    :entityCategory "logic_flow" ;
    :flowFrom :agentic_coding ;
    :flowSummary "Mythos creates the most value when used in long-running autonomous engineering loops with subagent coordination rather than synchronous hands-on use." ;
    :flowTo :capabilities_scope ;
    :flowVia :agentic_coding_whole_cycle,
        :subagent_coordination ;
    :groundedIn :agentic_coding_value_flow_quote ;
    :hasFlowStep :agentic_coding_value_flow_step_1,
        :agentic_coding_value_flow_step_2,
